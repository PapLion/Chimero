{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@renderer/*": ["../electron/src/renderer/src/*"],
      "@features/*": ["../electron/src/renderer/src/features/*"],
      "@shared/*": ["../electron/src/renderer/src/shared/*"],
      "@shared/utils": ["../electron/src/renderer/src/shared/utils.ts"],
      "@shared/store": ["../electron/src/renderer/src/shared/store.ts"],
      "@shared/queries": ["../electron/src/renderer/src/shared/queries.ts"],
      "@shared/api": ["../electron/src/renderer/src/shared/api.ts"],
      "@contracts/*": ["../../packages/shared/src/*"],
      "@packages/ui/*": ["../../packages/ui/*"],
      "@packages/db": ["../../packages/db/src/index.ts"],
      "@packages/db/*": ["../../packages/db/src/*"]
    }
  },
  "include": [
    "src/**/*",
    "server/**/*",
    "vite.config.ts",
    "../electron/src/renderer/src/**/*",
    "../../packages/**/*"
  ]
}
